{
  "name": "markdown-factory",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/markdown-factory/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build-base": {
      "command": "tsdown --config packages/markdown-factory/tsdown.config.ts",
      "outputs": ["{workspaceRoot}/dist/packages/markdown-factory"],
      "options": {
        "outputPath": "dist/packages/markdown-factory"
      }
    },
    "build": {
      "dependsOn": ["build-base"],
      "command": "tsx ./tools/extra-build-step.ts --project markdown-factory --targetName build-base"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/packages/markdown-factory"],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "../../coverage/packages/markdown-factory"
      }
    },
    "publish": {
      "dependsOn": ["build", "test"],
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npm publish dist/packages/markdown-factory"]
      }
    }
  }
}
